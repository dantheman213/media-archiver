{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Media Archiver",
  "version": "0.1.0",
  "identifier": "com.dantheman213.media-archiver",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Media Archiver",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "nsis-portable"],
    "windows": {
      "nsis": {
        "license": "../LICENSE",
        "installMode": "both",
        "languages": ["English"],
        "displayLanguageSelector": false,
        "template": "nsis/installer.nsi"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
